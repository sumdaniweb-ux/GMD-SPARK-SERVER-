const chatContainer = document.getElementById('chat-container');
const userInput = document.getElementById('userInput');
const filePreview = document.getElementById('filePreview');
const fileInfo = document.getElementById('fileInfo');
const securityBadge = document.getElementById('securityBadge');
let currentFile = null;
const defaultThemes = ['theme-dark', 'theme-gold', 'theme-blue', 'theme-green'];
let currentTheme = 0;
let customThemes = JSON.parse(localStorage.getItem('gmdSparkThemes')) || [];

// ================= سیکیورٹی اور API سیٹنگز =================
const GMD_CONFIG = {
  API_URL: 'https://192.168.1.100:8080/api/chat', // ← صرف یہاں اپنا سرور ایڈریس تبدیل کریں
  USE_API: true,
  SHA256_ENABLED: true,
  TIMEOUT_MS: 15000
};

async function sha256(msg) {
  if (!GMD_CONFIG.SHA256_ENABLED) return '';
  const buf = new TextEncoder().encode(msg);
  const hash = await crypto.subtle.digest('SHA-256', buf);
  return Array.from(new Uint8Array(hash)).map(b => b.toString(16).padStart(2, '0')).join('');
}

function sanitizeInput(t) { return t.replace(/[<>]/g, '').trim(); }

async function callSecureAPI(text, file) {
  const payload = { message: sanitizeInput(text), timestamp: new Date().toISOString(), hash: await sha256(text), file: file ? { name: file.name, size: file.size } : null };
  const ctrl = new AbortController();
  const timeout = setTimeout(() => ctrl.abort(), GMD_CONFIG.TIMEOUT_MS);
  try {
    const res = await fetch(GMD_CONFIG.API_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
      signal: ctrl.signal
    });
    clearTimeout(timeout);
    if (!res.ok) throw new Error('API Error');
    const data = await res.json();
    return data.reply || data.message || 'جواب موصول ہوا۔';
  } catch (e) {
    clearTimeout(timeout);
    return null;
  }
}
// ==========================================================

['bgColor', 'textColor', 'inputBgColor', 'userMsgColor', 'borderColor'].forEach(id => {  const c = document.getElementById(id), t = document.getElementById(id + 'Text');
  c.addEventListener('input', () => { t.value = c.value; updatePreview(); });
  t.addEventListener('input', () => { if (/^#[0-9A-Fa-f]{6}$/.test(t.value)) { c.value = t.value; updatePreview(); } });
});

function updatePreview() {
  const p = document.getElementById('themePreview');
  p.style.background = document.getElementById('bgColor').value;
  p.style.color = document.getElementById('textColor').value;
  p.style.border = `1px solid ${document.getElementById('borderColor').value}`;
}

function openThemeEditor() { document.getElementById('themeModal').classList.add('show'); renderSavedThemes(); }
function closeThemeEditor() { document.getElementById('themeModal').classList.remove('show'); }

function saveCustomTheme() {
  const name = document.getElementById('themeName').value.trim();
  if (!name) { alert('براہ کرم تھیم کا نام درج کریں'); return; }
  const theme = { name, id: 'custom-' + Date.now(), colors: { bg: document.getElementById('bgColor').value, text: document.getElementById('textColor').value, inputBg: document.getElementById('inputBgColor').value, userMsg: document.getElementById('userMsgColor').value, border: document.getElementById('borderColor').value } };
  customThemes.push(theme);
  localStorage.setItem('gmdSparkThemes', JSON.stringify(customThemes));
  applyCustomTheme(theme);
  renderSavedThemes();
  document.getElementById('themeName').value = '';
  alert('تھیم محفوظ ہو گیا!');
}

function applyCustomTheme(theme) {
  document.body.className = '';
  const s = document.createElement('style');
  s.id = 'custom-theme-style';
  s.textContent = `body{background:${theme.colors.bg};color:${theme.colors.text}}body header{background:${theme.colors.bg}}body .input-wrapper{background:${theme.colors.inputBg};border-color:${theme.colors.border}}body textarea{color:${theme.colors.text}}body .user-msg{background:${theme.colors.userMsg};border-color:${theme.colors.border}}body .bot-msg{background:transparent}`;
  const old = document.getElementById('custom-theme-style');
  if (old) old.remove();
  document.head.appendChild(s);
}

function renderSavedThemes() {
  const list = document.getElementById('savedThemesList');
  list.innerHTML = '';
  customThemes.forEach(t => {
    const item = document.createElement('div');
    item.className = 'theme-item';
    item.innerHTML = `<span class="theme-item-name">${t.name}</span><div class="theme-item-actions"><button class="btn-apply" onclick="applySavedTheme('${t.id}')">لگائیں</button><button class="btn-delete" onclick="deleteTheme('${t.id}')">حذف</button></div>`;
    list.appendChild(item);
  });
}

function applySavedTheme(id) { const t = customThemes.find(x => x.id === id); if (t) applyCustomTheme(t); }
function deleteTheme(id) { if (confirm('حذف کریں؟')) { customThemes = customThemes.filter(x => x.id !== id); localStorage.setItem('gmdSparkThemes', JSON.stringify(customThemes)); renderSavedThemes(); } }function exportThemes() { const b = new Blob([JSON.stringify(customThemes, null, 2)], { type: 'application/json' }); const a = document.createElement('a'); a.href = URL.createObjectURL(b); a.download = 'gmd-spark-themes.json'; a.click(); }
function importThemes(inp) { const f = inp.files[0]; if (!f) return; const r = new FileReader(); r.onload = e => { try { customThemes = [...customThemes, ...JSON.parse(e.target.result)]; localStorage.setItem('gmdSparkThemes', JSON.stringify(customThemes)); renderSavedThemes(); alert('امپورٹ ہو گیا!'); } catch { alert('غلط فائل'); } }; r.readAsText(f); }

userInput.addEventListener('keypress', e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); } });
userInput.addEventListener('input', function () { this.style.height = 'auto'; this.style.height = (this.scrollHeight) + 'px'; });

function handleFile(inp) { if (inp.files && inp.files[0]) { currentFile = inp.files[0]; fileInfo.textContent = '📎 ' + currentFile.name; filePreview.classList.add('show'); } }
function removeFile() { currentFile = null; document.getElementById('fileInput').value = ''; filePreview.classList.remove('show'); }

function addMessage(text, cls) { const d = document.createElement('div'); d.className = `message ${cls}`; d.textContent = text; chatContainer.appendChild(d); }

// ================= نیا sendMessage =================
async function sendMessage() {
  const text = userInput.value.trim();
  if (!text && !currentFile) return;
  if (text) addMessage(text, 'user-msg');
  if (currentFile) { const f = document.createElement('div'); f.className = 'message user-msg'; f.textContent = '📎 ' + currentFile.name; chatContainer.appendChild(f); }
  userInput.value = ''; userInput.style.height = 'auto'; removeFile(); chatContainer.scrollTop = chatContainer.scrollHeight;
  const typing = document.createElement('div'); typing.className = 'typing-indicator bot-msg'; typing.textContent = 'لکھ رہا ہے...'; typing.id = 'typingIndicator'; chatContainer.appendChild(typing);
  try {
    let reply = GMD_CONFIG.USE_API ? await callSecureAPI(text, currentFile) : null;
    if (!reply) { reply = getBotReply(text); if (securityBadge) securityBadge.textContent = '🔓 Local Mode'; }
    document.getElementById('typingIndicator')?.remove();
    addMessage(reply, 'bot-msg');
  } catch (e) { document.getElementById('typingIndicator')?.remove(); addMessage('معاف کیجئے، تکنیکی مسئلہ پیش آ گیا۔', 'bot-msg'); }
  chatContainer.scrollTop = chatContainer.scrollHeight;
}

function getBotReply(input) {
  input = (input || '').toLowerCase();
  if (input.includes('سلام') || input.includes('hi')) return 'وعلیکم السلام! کیسے ہیں آپ؟';
  if (input.includes('کیسے ہو')) return 'میں بالکل ٹھیک ہوں، آپ سنائیں؟';
  if (input.includes('نام')) return 'میرا نام GMD Spark ہے۔';
  return 'میں ابھی سیکھ رہا ہوں، لیکن آپ کا ساتھ بہت اچھا لگ رہا ہے!';
}

document.getElementById('themeModal').addEventListener('click', e => { if (e.target.id === 'themeModal') closeThemeEditor(); });
if (securityBadge && GMD_CONFIG.SHA256_ENABLED) securityBadge.textContent = '🔐 SHA-256 Active';